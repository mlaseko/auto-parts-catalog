{% extends 'base.html.twig' %}

{% block title %}{{ partGroup }} — Components{% endblock %}

{% block body %}
<div class="container">
    {{ include('blocks/_page_header.html.twig') }}

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('catalog_groups') }}">Parts Catalog</a></li>
            <li class="breadcrumb-item active">{{ partGroup }}</li>
        </ol>
    </nav>

    <div class="row mb-3">
        <div class="col">
            <h2>{{ partGroup }}</h2>
            <p class="text-muted">Select a component to view matching products.</p>
        </div>
    </div>

    {% if components is empty %}
        <div class="alert alert-info">No components found for this group.</div>
    {% else %}
        <div class="row row-cols-1 row-cols-md-3 g-3">
            {% for component in components %}
                <div class="col">
                    <a class="card h-100 text-decoration-none text-dark"
                       href="{{ path('catalog_results', {partGroup: partGroup, partComponent: component}) }}">
                        <div class="card-body">
                            <span class="fw-semibold">{{ component }}</span>
                        </div>
                    </a>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
