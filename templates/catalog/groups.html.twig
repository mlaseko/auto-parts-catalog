{% extends 'base.html.twig' %}

{% block title %}Parts Catalog — Browse by Group{% endblock %}

{% block body %}
<div class="container">
    {{ include('blocks/_page_header.html.twig') }}

    <div class="row mb-3">
        <div class="col">
            <h2>Browse Parts by Group</h2>
            <p class="text-muted">Select a part group to drill down into components and products.</p>
        </div>
        <div class="col-auto">
            <form class="d-flex gap-2" action="{{ path('catalog_search') }}" method="get">
                <input class="form-control" type="search" name="q" placeholder="Search by OEM / article number…" style="min-width:260px">
                <button class="btn btn-primary" type="submit">Search</button>
            </form>
        </div>
    </div>

    {% if groups is empty %}
        <div class="alert alert-info">No part groups found in the catalog.</div>
    {% else %}
        <div class="row row-cols-1 row-cols-md-3 g-3">
            {% for group in groups %}
                <div class="col">
                    <a class="card h-100 text-decoration-none text-dark"
                       href="{{ path('catalog_components', {partGroup: group}) }}">
                        <div class="card-body d-flex align-items-center gap-3">
                            <span class="fs-2">🔧</span>
                            <span class="fw-semibold">{{ group }}</span>
                        </div>
                    </a>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
